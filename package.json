{
  "name": "memos",
  "version": "0.1.0",
  "description": "MEMOS - Graphiti-based memory plugin for OpenClaw",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:llm": "MEMOS_RUN_LLM_TESTS=true MEMOS_ENABLE_LLM_IN_TESTS=true jest src/tests/llm.integration.test.ts --runInBand",
    "test:standalone": "node tests/standalone.test.js",
    "test:e2e": "node tests/e2e.test.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "memory",
    "graphiti",
    "knowledge-graph"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "prom-client": "^15.0.0"
  }
}
